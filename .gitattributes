# Normalize line endings across platforms
* text=auto

# Ruby files — always LF
*.rb text eol=lf
*.ru text eol=lf
Gemfile text eol=lf
Procfile text eol=lf

# Web files — always LF
*.tsx text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Windows scripts — CRLF
*.bat text eol=crlf

# Binary files — no conversion
*.db binary
*.png binary
*.jpg binary
*.ico binary
